{
  "name": "agent-tools",
  "version": "1.0.0",
  "description": "Unified tool layer for AI agents - MCP server and core executors for remote execution",
  "main": "dist/server.js",
  "type": "module",
  "exports": {
    ".": "./dist/core/index.js",
    "./core": "./dist/core/index.js",
    "./server": "./dist/server.js"
  },
  "scripts": {
