  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ssh2": "^1.15.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}