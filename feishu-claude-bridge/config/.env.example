# 服务器配置
PORT=3000
NODE_ENV=development

# ==================== 飞书配置 ====================
# 应用 ID 和 密钥（必需）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx
# 连接模式: webhook (需要公网域名) 或 long-connection (无需公网域名)
# 默认使用 webhook 模式
FEISHU_CONNECTION_MODE=webhook

# Webhook 模式需要以下配置（用于验证请求签名）
# 长连接模式不需要这些配置
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== 钉钉配置 ====================
# 是否启用钉钉平台
DINGTALK_ENABLED=true
# 连接模式: webhook (需要公网域名) 或 stream (无需公网域名)
# 推荐使用 stream 模式
DINGTALK_CONNECTION_MODE=stream
# 应用 AppKey 和 AppSecret（必需）
DINGTALK_APP_KEY=dingxxxxxxxxxxxxxxx
DINGTALK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AgentId（必需）
DINGTALK_AGENT_ID=xxxxxxxxxx

# Webhook 模式需要以下配置（用于验证请求签名）
# Stream 模式不需要这个配置
DINGTALK_ENCODING_AES_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================== Claude API 配置 ====================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_SYSTEM_PROMPT=你是一个友好、有帮助的AI助手。请用中文回复用户的问题。
# 可选：最大输出 token 数
# CLAUDE_MAX_TOKENS=4096

# ==================== 消息队列配置 ====================
MESSAGE_QUEUE_DIR=./messages
RESPONSE_QUEUE_DIR=./responses

# ==================== agent-tools 配置（可选）====================
# 用于远程命令执行和 GPU 操作
# 通过 SSH 连接到远程服务器
GPU_HOST=192.168.1.100
GPU_USER=username
GPU_SSH_PASSWD=password
MY_SUDO_PASSWD=sudo_password
TORCH_MUSA_DOCKER_IMAGE=registry.mthreads.com/public/musa-train:rc4.3.1-kuae2.1-20251014-juleng